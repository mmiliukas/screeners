[{"address1": "80 Tuas South Boulevard", "city": "Singapore", "zip": "637051", "country": "Singapore", "phone": "65 6265 1766", "fax": "65 6261 0738", "website": "https://www.seatrium.com", "industry": "Oil & Gas Equipment & Services", "industryKey": "oil-gas-equipment-services", "industryDisp": "Oil & Gas Equipment & Services", "sector": "Energy", "sectorKey": "energy", "sectorDisp": "Energy", "longBusinessSummary": "Seatrium Limited provides engineering solutions to the offshore, marine, and energy industries. It operates through Rigs & floaters, Repairs & upgrades, Offshore platforms and Specialised shipbuilding; Ship chartering; and Others segments. The company engages in the turnkey design, engineering, procurement, construction, and commissioning of offshore newbuilding and conversions; FSOs, FPSOs, FDPSOs, FPUs, and MOPUs; gas terminals, FLNGs, FSRUs, and Gravifloat; offshore oil and gas fixed platforms; onshore LNG and plant modules; jack-ups, semi-submersibles, and drill ships; and TLPs, SPARs, and SSP solutions. It is also involved in the dry-docking, repair, refurbishment, retrofitting, life-extension, upgrading, and conversion of offshore and marine vessels and structures; gas carriers; cruise ships, ferries, and yachts; floating production vessels; mobile offshore drilling units, jack-ups, and semi submersibles; heavy lift vessels; and specialized projects, including jumboisation and dejumboisation. In addition, the company offers turnkey engineering, procurement, construction, transportation, installation, offshore hook-up, commissioning, and brownfield solutions; high voltage direct current (HVDC) converter stations, high voltage alternating current (HVAC) substations, and wind turbine foundations; and wind turbine installation vessels, floating offshore wind turbines, floating wind-HVDC stations, and HVAC stations. Further, it provides specialized shipbuilding solutions comprising ferry, RoPax, cruise, renewable energy support, offshore support, naval support and security, and research and scientific survey vessels. Additionally, it engages in LNG and ammonia assets; clean tech and energy transition; energies and alternative fuel value chain solutions; and digitalisation solutions. The company was formerly known as Sembcorp Marine Ltd and changed its name to Seatrium Limited in April 2023. Seatrium Limited was incorporated in 1963 and is headquartered in Singapore.", "fullTimeEmployees": 24000, "companyOfficers": [{"maxAge": 1, "name": "Mr. Leng Yeow  Ong", "age": 50, "title": "CEO & Executive Director", "yearBorn": 1975, "fiscalYear": 2025, "totalPay": 2386487, "exercisedValue": 0, "unexercisedValue": 0}, {"maxAge": 1, "name": "Dr. Hsueh-Jeng  Lu", "title": "Chief Financial Officer", "fiscalYear": 2025, "exercisedValue": 0, "unexercisedValue": 0}, {"maxAge": 1, "name": "Mr. How Jat  Chor", "age": 63, "title": "Chief Operating Officer", "yearBorn": 1962, "fiscalYear": 2025, "exercisedValue": 0, "unexercisedValue": 0}, {"maxAge": 1, "name": "Mr. Aziz Amirali  Merchant", "age": 60, "title": "Executive Vice President of Technology & New Product Development", "yearBorn": 1965, "fiscalYear": 2025, "exercisedValue": 0, "unexercisedValue": 0}, {"maxAge": 1, "name": "Ms. Amelia  Lee", "title": "Head of Investor Relations & Corporate Communications", "fiscalYear": 2025, "exercisedValue": 0, "unexercisedValue": 0}, {"maxAge": 1, "name": "Madam Lee Hwa  Looi", "title": "General Counsel & Company Secretary", "fiscalYear": 2025, "exercisedValue": 0, "unexercisedValue": 0}, {"maxAge": 1, "name": "Ms. Wang  Huiping", "title": "Assistant Vice President of Marketing", "fiscalYear": 2025, "exercisedValue": 0, "unexercisedValue": 0}, {"maxAge": 1, "name": "Dr. Chay Hoon  Lee", "title": "Chief People Officer", "fiscalYear": 2025, "exercisedValue": 0, "unexercisedValue": 0}, {"maxAge": 1, "name": "Mr. William  Gu", "title": "Executive Vice President, Seatrium Energy -Marketing", "fiscalYear": 2025, "totalPay": 335601, "exercisedVal