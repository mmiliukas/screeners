[{"address1": "35 West Pearce Street", "address2": "Unit 12 & 13", "city": "Richmond Hill", "state": "ON", "zip": "L4B 3A9", "country": "Canada", "phone": "905-948-8266", "website": "https://viqsolutions.com", "industry": "Software - Application", "industryKey": "software-application", "industryDisp": "Software - Application", "sector": "Technology", "sectorKey": "technology", "sectorDisp": "Technology", "longBusinessSummary": "VIQ Solutions Inc. operates as a technology and service platform provider for digital evidence capture, retrieval, and content management in Australia, the United States, the United Kingdom, Canada, and internationally. It operates through the Technology and Related Revenue, and Technology Services segments. The Technology and Related Revenue segment develops, distributes, and licenses computer-based digital solutions based on its technology. The Technology Services segment provides recording and transcription services. The company offers CapturePro that securely speeds the capture, creation, and management of large volumes of information, as well as preserves and secures the spoken word and video image, and delivers data; MobileMic Pro for capturing and managing incident reports, recorded statements, case notes, and other information; and NetScribe, a transcription creation and management platform that consolidates, accelerates, and optimizes workflows. It also provides aiAssist, a multi-tenant workflow and analysis platform to manage, convert, and analyze large volumes of audio and visual content; FirstDraft that converts audio files to text to provide access to interviews, testimonies, recorded calls, and dictations; Carbon, a media-centric and web-based platform that uses automatic speech-to-text; and AccessPoint, a secure online portal to simplify court recording management, playback, and distribution. The company serves courts, law firms and enforcement, insurance, government, corporate and finance, media broadcasting, and transcription industries. VIQ Solutions Inc. was incorporated in 2004 and is headquartered in Richmond Hill, Canada.", "companyOfficers": [{"maxAge": 1, "name": "Mr. Larry Douglas Taylor CMA, CMC, CPA", "age": 68, "title": "CEO & Director", "yearBorn": 1957, "fiscalYear": 2025, "totalPay": 57500, "exercisedValue": 0, "unexercisedValue": 0}, {"maxAge": 1, "name": "Ms. Elizabeth  Pennell", "title": "Senior Vice President of Global Product and Operations", "fiscalYear": 2025, "totalPay": 273654, "exercisedValue": 0, "unexercisedValue": 0}, {"maxAge": 1, "name": "Mr. Michael Andrew Wolfe CA, CPA, M.B.A.", "age": 59, "title": "Chief Financial Officer", "yearBorn": 1966, "fiscalYear": 2025, "exercisedValue": 0, "unexercisedValue": 0}, {"maxAge": 1, "name": "Mr. Tim  Johnson", "title": "Senior Vice President Of International", "fiscalYear": 2025, "exercisedValue": 0, "unexercisedValue": 0}], "compensationAsOfEpochDate": 1767139200, "executiveTeam": [], "maxAge": 86400, "priceHint": 4, "previousClose": 0.0557, "open": 0.0705, "dayLow": 0.0705, "dayHigh": 0.0705, "regularMarketPreviousClose": 0.0557, "regularMarketOpen": 0.0705, "regularMarketDayLow": 0.0705, "regularMarketDayHigh": 0.0705, "payoutRatio": 0.0, "beta": 0.981, "volume": 777, "regularMarketVolume": 777, "averageVolume": 1943, "averageVolume10days": 1400, "averageDailyVolume10Day": 1400, "bid": 0.0471, "ask": 0.0743, "bidSize": 35000, "askSize": 50000, "marketCap": 4375699, "nonDilutedMarketCap": 4466854, "fiftyTwoWeekLow": 0.03, "fiftyTwoWeekHigh": 0.1688, "allTimeHigh": 7.92, "allTimeLow": 0.03, "priceToSalesTrailing12Months": 0.10496729, "fiftyDayAverage": 0.059112, "twoHundredDayAverage": 0.102341, "trailingAnnualDividendRate": 0.0, "trailingAnnualDividendYield": 0.0, "currency": "USD", "tradeable": false, "enterpriseValue": 22033030, "profitMargins": -0.28259, "floatShares": 44613113, "sharesOutstanding": 70462155, "sharesShort": 181872, "sharesShortPriorMonth": 221130, "sharesShortPreviousMonthDate": 1692057600, "dateS