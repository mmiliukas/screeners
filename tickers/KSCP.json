[{"address1": "1070 Terra Bella Avenue", "city": "Mountain View", "state": "CA", "zip": "94043", "country": "United States", "phone": "650 924 1025", "website": "https://www.knightscope.com", "industry": "Security & Protection Services", "industryKey": "security-protection-services", "industryDisp": "Security & Protection Services", "sector": "Industrials", "sectorKey": "industrials", "sectorDisp": "Industrials", "longBusinessSummary": "Knightscope, Inc. designs, develops, manufactures, markets, deploys, and supports autonomous security robots (ASR) in the United States. The company provides K3 Indoor ASR for enclosed spaces, such as corporate offices, hospitals, and shopping centers; K5 Outdoor ASR for external environments comprising parking lots, logistics facilities, and corporate campuses; K1 Hemisphere, a stationary unit for indoor and outdoor use; and Knightscope Security Operations Center (KSOC), a browser-based user interface that enables clients to monitor and manage their ASRs in real-time. It also offers emergency communication solutions, including K1 Blue Light Towers that are solar-powered emergency communication stations, which provides immediate access to emergency response personnel or law enforcement in parking lots, public parks, and college campuses; K1 Blue Light E-Phone, a compact emergency phone system that delivers one-touch connectivity and features a high-visibility blue strobe light, which is suitable for locations, such as parking lots, building interiors, college campuses, electric vehicle charging stations, transit stations, and office spaces; K1 Call Box, a small emergency call box system that provides a simple housing and interface for one-touch connection to emergency services for indoor and outdoor use in areas comprising bridges, highways, parks, metro stations, military installations, and remote parking lots; and Knightscope Emergency Management System (KEMS), a cloud-based application that monitors the health and status of deployed emergency communication devices. Knightscope, Inc. was incorporated in 2013 and is headquartered in Mountain View, California.", "fullTimeEmployees": 71, "companyOfficers": [{"maxAge": 1, "name": "Mr. William Santana Li", "age": 55, "title": "President, CEO & Chairman", "yearBorn": 1970, "fiscalYear": 2024, "totalPay": 1006593, "exercisedValue": 0, "unexercisedValue": 0}, {"maxAge": 1, "name": "Mr. Apoorv S. Dwivedi", "age": 43, "title": "Executive VP, Secretary & CFO", "yearBorn": 1982, "fiscalYear": 2024, "totalPay": 344658, "exercisedValue": 0, "unexercisedValue": 0}, {"maxAge": 1, "name": "Ms. Mercedes  Soria", "age": 51, "title": "Executive VP, Chief Information Security Officer & Chief Intelligence Officer", "yearBorn": 1974, "fiscalYear": 2024, "totalPay": 351593, "exercisedValue": 0, "unexercisedValue": 0}, {"maxAge": 1, "name": "Mr. Aaron J. Lehnhardt", "age": 52, "title": "Executive VP & Chief Design Officer", "yearBorn": 1973, "fiscalYear": 2024, "exercisedValue": 0, "unexercisedValue": 0}, {"maxAge": 1, "name": "Mr. Ronald J. Gallegos", "title": "Senior Vice President of Revenue", "fiscalYear": 2024, "exercisedValue": 0, "unexercisedValue": 0}], "compensationAsOfEpochDate": 1735603200, "executiveTeam": [], "maxAge": 86400, "priceHint": 4, "previousClose": 4.11, "open": 4.15, "dayLow": 3.92, "dayHigh": 4.23, "regularMarketPreviousClose": 4.11, "regularMarketOpen": 4.15, "regularMarketDayLow": 3.92, "regularMarketDayHigh": 4.23, "payoutRatio": 0.0, "beta": 1.713, "forwardPE": -1.6866953, "volume": 284549, "regularMarketVolume": 284549, "averageVolume": 366393, "averageVolume10days": 285260, "averageDailyVolume10Day": 285260, "bid": 3.02, "ask": 5.06, "bidSize": 1, "askSize": 1, "marketCap": 58430188, "nonDilutedMarketCap": 58430185, "fiftyTwoWeekLow": 2.45, "fiftyTwoWeekHigh": 10.14, "allTimeHigh": 1375.0, "allTimeLow": 2.45, "priceToSalesTrailing12Months": 5.032747, "fiftyDayAverage": 3.9088, "twoHundredDayAverage": 5.165175, "trailingAnnualDividendRat