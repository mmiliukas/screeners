[{"address1": "3240 S. Central Avenue", "city": "Cicero", "state": "IL", "zip": "60804", "country": "United States", "phone": "708 780 4800", "website": "https://www.bwen.com", "industry": "Specialty Industrial Machinery", "industryKey": "specialty-industrial-machinery", "industryDisp": "Specialty Industrial Machinery", "sector": "Industrials", "sectorKey": "industrials", "sectorDisp": "Industrials", "longBusinessSummary": "Broadwind, Inc. manufactures and sells structures, equipment, and components power generation, critical infrastructure, and other specialized applications in the United States. The company operates through Heavy Fabrications, Gearing, and Industrial Solutions segments. The Heavy Fabrications segment provides fabrications to customers in a range of industrial markets. It offers steel towers and adapters primarily to wind turbine manufacturers. The Gearing segment provides gearing, gearboxes, and precision machined components to a range of customers in diverse markets, including power generation, onshore and offshore oil and gas fracking and drilling, material handling, wind energy, surface and underground mining, steel, infrastructure, marine, defense, and other industrial markets. This segment also offers heat treat services for aftermarket and original equipment manufacturer applications. The Industrial Solutions segment provides supply chain solutions, light fabrication, inventory management, and kitting and assembly services for combined cycle natural gas turbine market. The Industrial Solutions segment provides supply chain solutions for offering instrumentation and controls, valve assemblies, sensor devices, fuel system components, electrical junction boxes and wiring, and electromechanical devices; and light fabrication, inventory management, and kitting and assembly services for combined cycle natural gas turbine market, as well as packaging solutions and fabricated panels and sub-assemblies. It sells its products to the energy, mining, and infrastructure sectors through its direct sales force and independent sales agents. The company was formerly known as Broadwind Energy, Inc. and changed its name to Broadwind, Inc. in May 2020. Broadwind, Inc. is headquartered in Cicero, Illinois.", "fullTimeEmployees": 341, "companyOfficers": [{"maxAge": 1, "name": "Mr. Eric B. Blashford", "age": 61, "title": "CEO, President & Director", "yearBorn": 1964, "fiscalYear": 2025, "totalPay": 497672, "exercisedValue": 0, "unexercisedValue": 0}, {"maxAge": 1, "name": "Mr. Thomas A. Ciccone", "age": 50, "title": "VP & CFO", "yearBorn": 1975, "fiscalYear": 2025, "totalPay": 276487, "exercisedValue": 0, "unexercisedValue": 0}], "auditRisk": 7, "boardRisk": 3, "compensationRisk": 3, "shareHolderRightsRisk": 2, "overallRisk": 2, "governanceEpochDate": 1775001600, "compensationAsOfEpochDate": 1767139200, "executiveTeam": [], "maxAge": 86400, "priceHint": 4, "previousClose": 2.24, "open": 2.26, "dayLow": 2.22, "dayHigh": 2.38, "regularMarketPreviousClose": 2.24, "regularMarketOpen": 2.26, "regularMarketDayLow": 2.22, "regularMarketDayHigh": 2.38, "payoutRatio": 0.0, "beta": 1.54, "trailingPE": 10.173912, "forwardPE": 20.647665, "volume": 119217, "regularMarketVolume": 119217, "averageVolume": 178159, "averageVolume10days": 87030, "averageDailyVolume10Day": 87030, "bid": 2.29, "ask": 2.37, "bidSize": 1, "askSize": 1, "marketCap": 54765628, "nonDilutedMarketCap": 54765631, "fiftyTwoWeekLow": 1.45, "fiftyTwoWeekHigh": 4.15, "allTimeHigh": 290.0, "allTimeLow": 1.12, "priceToSalesTrailing12Months": 0.34650385, "fiftyDayAverage": 2.2758, "twoHundredDayAverage": 2.4981, "trailingAnnualDividendRate": 0.0, "trailingAnnualDividendYield": 0.0, "currency": "USD", "tradeable": false, "enterpriseValue": 82372072, "profitMargins": 0.03317, "floatShares": 20210157, "sharesOutstanding": 23404116, "sharesShort": 41487, "sharesShortPriorMonth": 114678, "sharesShortPreviousMonthDate": 1772150400, "dateShortInterest": 1774915200, "sharesPercentSha