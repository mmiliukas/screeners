[{"address1": "28 West Grand Avenue", "address2": "Suite 3", "city": "Montvale", "state": "NJ", "zip": "07645", "country": "United States", "phone": "201 225 0190", "website": "https://www.tingogroup.com", "industry": "Software - Application", "industryKey": "software-application", "industryDisp": "Software - Application", "sector": "Technology", "sectorKey": "technology", "sectorDisp": "Technology", "longBusinessSummary": "Tingo Group, Inc. engages in the financial technology and agri-fintech businesses, delivering financial inclusions and financial upliftment to rural farming communities in Africa, Southeast Asia, the Middle East, and internationally. It operates through Verticals and Technology, Online Stock Trading, Food Processing, Export and Commodity Trading, and Comprehensive Platform Service segments. The company's Verticals and Technology segment develops an insurance platform for the Chinese market. Its Comprehensive Platform Service segment develops an agri-fintech marketplace platform platform, which enables customers to trade agricultural produce and to purchase farming inputs, to recharge airtime and data, to pay bills and utilities, to arrange insurance, and to procure finance. The Online Stock Trading segment develops a technology investment trading platform. Its Food Processing segment purchases crops and raw foods, before processing them into finished food products through arrangements with third-party rice mills, cashew processing plants, and other food processing companies. The Export and Commodity Trading segment exports and trades in agricultural commodities and processed foods. The company was formerly known as MICT, Inc. and changed its name to Tingo Group, Inc. in February 2023. Tingo Group, Inc. is based in Montvale, New Jersey.", "fullTimeEmployees": 797, "companyOfficers": [{"maxAge": 1, "name": "Mr. Hao  Chen", "age": 43, "title": "Group Interim Chief Financial Officer", "yearBorn": 1982, "fiscalYear": 2022, "totalPay": 216000, "exercis