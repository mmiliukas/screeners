[{"address1": "1525 Kautz Road", "address2": "Suite 600", "city": "West Chicago", "state": "IL", "zip": "60185", "country": "United States", "phone": "630 377 0486", "website": "https://www.titan-intl.com", "industry": "Farm & Heavy Construction Machinery", "industryKey": "farm-heavy-construction-machinery", "industryDisp": "Farm & Heavy Construction Machinery", "sector": "Industrials", "sectorKey": "industrials", "sectorDisp": "Industrials", "longBusinessSummary": "Titan International, Inc., together with its subsidiaries, manufactures and sells wheels, tires, and undercarriage systems and components for off-highway industry in North America, Europe, CIS, Latin America, Asia, and internationally. It operates through Agricultural, Earthmoving/Construction, and Consumer segments. The company offers wheels, tires, and components for various agricultural equipment, including tractors, combines, skidders, plows, planters, and irrigation equipment; and agricultural tires under the Goodyear Farm Tire, Titan Tire, Carlstar, ACES, and Voltyre-Prom brands. It also provides wheels, tires, and undercarriage systems and components for various types of off-the-road earthmoving, mining, military, construction, and forestry equipment, such as skid steers, aerial lifts, cranes, graders and levelers, scrapers, self-propelled shovel loaders, articulated dump trucks, load transporters, haul trucks, backhoe loaders, crawler tractors, lattice cranes, shovels, and hydraulic excavators under the Titan brand. In addition, the company manufactures and distributes wheels and tires for end-market verticals comprising outdoor power equipment, power sports, and high speed trailers; and manufactures and sells small to midsize agricultural tires under the Carlstar, ITP, Black Rock, Goodyear, and Unique brands. Further, it is involved in the provision of wheel and tire assembly services; manufactures bias truck and light truck tires; and sale of rubber stocks. The company sells its products directly to original equipment manufacturers, as well as to the aftermarket through independent distributors, equipment dealers, and its distribution centers. Titan International, Inc. was founded in 1890 and is headquartered in West Chicago, Illinois.", "fullTimeEmployees": 8200, "companyOfficers": [{"maxAge": 1, "name": "Mr. Paul George Reitz", "age": 53, "title": "CEO, President & Director", "yearBorn": 1972, "fiscalYear": 2025, "totalPay": 1736811, "exercisedValue": 0, "unexercisedValue": 0}, {"maxAge": 1, "name": "Mr. Anthony C. Eheli", "age": 47, "title": "Senior VP & Chief Financial Officer", "yearBorn": 1978, "fiscalYear": 2025, "totalPay": 421174, "exercisedValue": 0, "unexercisedValue": 0}, {"maxAge": 1, "name": "Mr. David A. Martin CPA", "age": 57, "title": "Senior VP & Chief Transformation Officer", "yearBorn": 1968, "fiscalYear": 2025, "totalPay": 769303, "exercisedValue": 0, "unexercisedValue": 0}, {"maxAge": 1, "name": "Mr. Max R. Narancich", "age": 49, "title": "Chief Operating Officer of Titan Specialty", "yearBorn": 1976, "fiscalYear": 2025, "totalPay": 694538, "exercisedValue": 0, "unexercisedValue": 0}, {"maxAge": 1, "name": "Mr. James M. Pach", "age": 44, "title": "VP & Chief Accounting Officer", "yearBorn": 1981, "fiscalYear": 2025, "exercisedValue": 0, "unexercisedValue": 0}, {"maxAge": 1, "name": "Paul  Hawkins", "title": "Senior Vice President of Aftermarket Sales & Marketing", "fiscalYear": 2025, "exercisedValue": 0, "unexercisedValue": 0}, {"maxAge": 1, "name": "Ms. Maria Cecilia La Manna", "age": 61, "title": "Chief Executive Officer of ITM Group", "yearBorn": 1964, "fiscalYear": 2025, "exercisedValue": 0, "unexercisedValue": 0}, {"maxAge": 1, "name": "Mr. Todd A. Shoot CPA", "title": "Senior VP & Treasurer", "fiscalYear": 2025, "exercisedValue": 0, "unexercisedValue": 0}], "auditRisk": 7, "boardRisk": 8, "compensationRisk": 7, "shareHolderRightsRisk": 2, "overallRisk": 5, "governanceEpochDate": 1782864000, "compensationAsOfEpochDate": 17671392