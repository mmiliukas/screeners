[{"address1": "9715 Key West Avenue", "city": "Rockville", "state": "MD", "zip": "20850", "country": "United States", "phone": "301 838 2500", "website": "https://www.supernus.com", "industry": "Drug Manufacturers - Specialty & Generic", "industryKey": "drug-manufacturers-specialty-generic", "industryDisp": "Drug Manufacturers - Specialty & Generic", "sector": "Healthcare", "sectorKey": "healthcare", "sectorDisp": "Healthcare", "longBusinessSummary": "Supernus Pharmaceuticals, Inc., a biopharmaceutical company, engages in the development and commercialization of products for the treatment of central nervous system (CNS) diseases in the United States. It offers Qelbree, a non-stimulant indicated for the treatment of attention-deficit hyperactivity disorder (ADHD); GOCOVRI for the treatment of dyskinesia and levodopa/carbidopa in patients with Parkinson's Disease (PD); Oxtellar XR, an extended-release oxcarbazepine product indicated for the monotherapy treatment of partial onset epilepsy seizures; and APOKYN for the acute and intermittent treatment of hypomobility or off episodes in patients with advanced PD. It also provides Trokendi XR, an extended release topiramate product indicated for the treatment of epilepsy, as well as for the prophylaxis of migraine headache; XADAGO for the treatment of levodopa/carbidopa in patients with PD experiencing off episodes; and MYOBLOC, a Type B toxin product indicated for the treatment of cervical dystonia and chronic sialorrhea. In addition, the company develops ONAPGO, which received FDA approval, for the treatment of motor fluctuations in adults with advanced PD; SPN-817, a first-in-class selective acetylcholinesterase inhibitor, which is in Phase 2 clinical trial, for the treatment of epilepsy, partial seizures, Dravet syndrome, and Lennox-Gaustaut syndrome; SPN-820, a small molecule in Phase 2 clinical trial for treating resistant depression; and SPN-443, a stimulant in Phase 1 trial for the treatment of ADHD/CNS. It markets and sells its products through pharmaceutical wholesalers, specialty pharmacies, and distributors. It has a development agreement with Navitor Inc. for the conduct of Phase 2 clinical program of SPN-820. Supernus Pharmaceuticals, Inc. was incorporated in 2005 and is based in Rockville, Maryland.", "fullTimeEmployees": 778, "companyOfficers": [{"maxAge": 1, "name": "Mr. Jack A. Khattar M.B.A.", "age": 64, "title": "Founder, President, CEO, Secretary & Director", "yearBorn": 1961, "fiscalYear": 2025, "totalPay": 1934983, "exercisedValue": 14903848, "unexercisedValue": 24295868}, {"maxAge": 1, "name": "Mr. Timothy C. Dec", "age": 66, "title": "Senior VP & CFO", "yearBorn": 1959, "fiscalYear": 2025, "totalPay": 778940, "exercisedValue": 0, "unexercisedValue": 2913975}, {"maxAge": 1, "name": "Dr. Padmanabh P. Bhatt Ph.D.", "age": 68, "title": "Chief Scientific Officer & Senior VP of Intellectual Property", "yearBorn": 1957, "fiscalYear": 2025, "totalPay": 665175, "exercisedValue": 128359, "unexercisedValue": 1303683}, {"maxAge": 1, "name": "Mr. Frank  Mottola", "age": 53, "title": "Senior VP & Chief Technology Operations Officer", "yearBorn": 1972, "fiscalYear": 2025, "totalPay": 634447, "exercisedValue": 905296, "unexercisedValue": 1627200}, {"maxAge": 1, "name": "Dr. Jonathan  Rubin M.B.A., M.D.", "age": 64, "title": "Senior VP of Research & Development and Chief Medical Officer", "yearBorn": 1961, "fiscalYear": 2025, "totalPay": 722477, "exercisedValue": 0, "unexercisedValue": 1463025}, {"maxAge": 1, "name": "Mr. Kevin T. Anderson Esq.", "age": 63, "title": "Compliance Officer", "yearBorn": 1962, "fiscalYear": 2025, "exercisedValue": 0, "unexercisedValue": 0}, {"maxAge": 1, "name": "Mr. Taylor  Raiford", "title": "Senior Vice President of Sales", "fiscalYear": 2025, "exercisedValue": 0, "unexercisedValue": 0}, {"maxAge": 1, "name": "Dr. William Todd Horich M.B.A., Ph.D.", "age": 52, "title": "Senior VP & Chief Commercial Officer", "yearBorn": 1973, "fiscalYear": 2025