[{"address1": "1 Commvault Way", "city": "Tinton Falls", "state": "NJ", "zip": "07724", "country": "United States", "phone": "732 870 4000", "fax": "732 870 4525", "website": "https://www.commvault.com", "industry": "Software - Application", "industryKey": "software-application", "industryDisp": "Software - Application", "sector": "Technology", "sectorKey": "technology", "sectorDisp": "Technology", "longBusinessSummary": "Commvault Systems, Inc. provides cyber resiliency solutions for enterprises to protect, secure, and recover data, applications, and identity system. The company offers Operational Recovery for backup and recovery capabilities in hybrid enterprise workloads, such as backup, restore, recovery validation, and policy-based data movement to cloud storage; Autonomous Recovery, which adds automation, orchestration, and validation intended to reduce recovery times, downtime, and operational complexity; and Cyber Recovery, which adds cyber preparedness, threat detection, and clean recovery features to help organizations respond to ransomware and other cyber incidents. The company also provides Commvault Cleanroom Recovery, an isolated and on-demand recovery environment in the cloud; Commvault HyperScale Grid, an integrated and scale-out data protection solution; Commvault HyperScale Flex, a data protection solution designed to support enterprise-scale environments and large-volume data workloads; and Commvault Threatscan to help identify and isolate malicious or anomalous data within backup environments. In addition, it offers Commvault Cloud Air Gap Protect for isolated cloud storage; Commvault's Compliance, which includes reporting, auditing, and logging; Commvault's Cloud Rewind for data recovery with automated cloud application and infrastructure rebuild capabilities; and Commvault's Clumio Backtrack to revert cloud objects and datasets to a prior point in time. Further, the company provides professional and customer support services comprising real-time support, support engineers, customer success options, technology consulting services, recovery services, education services, and cyber resilience managed services. It operates in the United States, Canada, and Latin America, as well as in Europe, the Middle East, Africa, Australia, India, Southeast Asia, and China. Commvault Systems, Inc. was incorporated in 1996 and is headquartered in Tinton Falls, New Jersey.", "fullTimeEmployees": 3300, "companyOfficers": [{"maxAge": 1, "name": "Mr. Sanjay  Mirchandani", "age": 61, "title": "President, CEO & Director", "yearBorn": 1964, "fiscalYear": 2026, "totalPay": 1862714, "exercisedValue": 0, "unexercisedValue": 0}, {"maxAge": 1, "name": "Mr. Gary  Merrill", "age": 50, "title": "Chief Financial Officer", "yearBorn": 1975, "fiscalYear": 2026, "totalPay": 1144429, "exercisedValue": 0, "unexercisedValue": 0}, {"maxAge": 1, "name": "Ms. Danielle  Abrahamsen", "age": 34, "title": "Chief Accounting Officer", "yearBorn": 1991, "fiscalYear": 2026, "totalPay": 649293, "exercisedValue": 0, "unexercisedValue": 0}, {"maxAge": 1, "name": "Mr. William Geoffrey Haydon", "age": 60, "title": "President of Customer & Field Operations", "yearBorn": 1965, "fiscalYear": 2026, "totalPay": 11875, "exercisedValue": 0, "unexercisedValue": 0}, {"maxAge": 1, "name": "Mr. Pranay  Ahlawat", "title": "Chief Technology & AI Officer", "fiscalYear": 2026, "exercisedValue": 0, "unexercisedValue": 0}, {"maxAge": 1, "name": "Ms. Ha  Hoang", "title": "Chief Information Officer", "fiscalYear": 2026, "exercisedValue": 0, "unexercisedValue": 0}, {"maxAge": 1, "name": "Mr. Michael John Melnyk C.F.A.", "title": "Head of Investor Relations", "fiscalYear": 2026, "exercisedValue": 0, "unexercisedValue": 0}, {"maxAge": 1, "name": "Ms. Danielle K. Sheer J.D.", "age": 44, "title": "Chief Legal & Trust Officer and Corporate Secretary", "yearBorn": 1981, "fiscalYear": 2026, "exercisedValue": 0, "unexercisedValue": 0}, {"maxAge": 1, "name": "Ms. Anna  Griffin", "age": 54,