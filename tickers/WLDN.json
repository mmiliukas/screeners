 various other special districts and agencies. Willdan Group, Inc. was founded in 1964 and is headquartered in Anaheim, California.", "fullTimeEmployees": 1814, "companyOfficers": [{"maxAge": 1, "name": "Mr. Michael A. Bieber", "age": 56, "title": "CEO, Director & President", "yearBorn": 1969, "fiscalYear": 2025, "totalPay": 1810511, "exercisedValue": 3006270, "unexercisedValue": 7425608}, {"maxAge": 1, "name": "Mr. Creighton K. Early", "age": 72, "title": "Executive VP & CFO", "yearBorn": 1953, "fiscalYear": 2025, "totalPay": 970609, "exercisedValue": 939041, "unexercisedValue": 981309}, {"maxAge": 1, "name": "Mr. Micah H. Chen J.D.", "age": 53, "title": "Executive VP & General Counsel", "yearBorn": 1972, "fiscalYear": 2025, "totalPay": 925242, "exercisedValue": 660360, "unexercisedValue": 2834800}, {"maxAge": 1, "name": "Mr. Albert Leo Kaschalk CPA", "title": "Vice President of Investor Relations", "fiscalYear": 2025, "exercisedValue": 0, "unexercisedValue": 0}, {"maxAge": 1, "name": "Ms. Kate M. Nguyen", "title": "Secretary", "fiscalYear": 2025, "exercisedValue": 0, "unexercisedValue": 0}], "auditRisk": 4, "boardRisk": 5, "compensationRisk": 2, "shareHolderRightsRisk": 7, "overallRisk": 4, "governanceEpochDate": 1782864000, "compensationAsOfEpochDate": 1767139200, "irWebsite": "http://ir.willdangroup.com/", "executiveTeam": [], "maxAge": 86400, "priceHint": 2, "previousClose": 74.98, "open": 73.63, "dayLow": 72.63, "dayHigh": 74.97, "regularMarketPreviousClose": 74.98, "regularMarketOpen": 73.63, "regularMarketDayLow": 72.63, "regularMarketDayHigh": 74.97, "payoutRatio": 0.0, "beta": 1.128, "trailingPE": 19.54301, "forwardPE": 13.71698, "volume": 168549, "regularMarketVolume": 168549, "averageVolume": 399753, "averageVolume10days": 322820, "averageDailyVolume10Day": 322820, "bid": 53.45, "ask": 93.69, "bidSize": 1, "askSize": 2, "marketCap": 1098541056, "nonDilutedMarketCap": 1098541056, "fiftyTwoWeekLow": 64.67, "fiftyTwoWeekHigh": 137.0, "allTimeHigh": 137.0, "