[{"address1": "210 George Street", "address2": "Level 8", "city": "Sydney", "state": "NSW", "zip": "2000", "country": "Australia", "phone": "61 2 9290 9606", "fax": "61 2 9279 0664", "website": "https://brainchip.com", "industry": "Semiconductors", "industryKey": "semiconductors", "industryDisp": "Semiconductors", "sector": "Technology", "sectorKey": "technology", "sectorDisp": "Technology", "longBusinessSummary": "BrainChip Holdings Ltd develops software and hardware accelerated solutions for artificial intelligence and machine learning applications in North America, Asia Pacific, Europe, the Middle East, and Asia Pacific. The company primarily focuses on development of Akida Neuromorphic Processor to provide ultra-low power and AI Edge Network for vision, audio, olfactory, and smart transducer applications. It also offers Akida IP, a neural processor; MetaTF software development tools, which is used for creation, training, testing, and deployment of neutral network; Akida Cloud, a service that provides a pre-configured environment for system and chip designers; and Akida GenAI FPGA, a hardware development target to install and exercise Akida GenAI IP core configurations to execute neural models for validation and system integration for system and chip designers. In addition, the company provides hardware development tools comprising AKD1000 PCIe Development Board, a compact platform designed to accelerate Edge AI development; Akida M.2 AKD1000 Card which accelerates CNN-based neural network models; AKIDA 1 Edge AI Box, a compact system with the capability to execute diverse AI applications at the edge; Akida FPGA Platform, a hardware product for loading Akida IP configurations and neural models; and Akida AKD1000 System-on-Chip, a event domain neural processing devices. Further, it offers Akida Model Zoo comprising AkidaNet/Object Detection, AkidaNet/Object Classification/Recognition, AkidaNet/Regression, AkidaNet/Face Recognition, AkidaNet/Keyword Spotting, AkidaNet/Point Cloud Classification, AkidaNet/TENN Gesture Recognition Model, and AkidaNet/TENN Eye Tracking Model; and TENNs Models which includes AkidaNet/TENN Audio Denoising Model, AkidaNet/TENN Automatic Speech Recognition Model, and AkidaNet/ TENN Large Language Model. The company was formerly known as Aziana Limited. BrainChip Holdings Ltd is based in Sydney, Australia.", "fullTimeEmployees": 71, "companyOfficers": [{"maxAge": 1, "name": "Mr. Sean  Hehir B.S., M.B.A.", "title": "CEO, MD & Executive Director", "fiscalYear": 2025, "totalPay": 502759, "exercisedValue": 0, "unexercisedValue": 0}, {"maxAge": 1, "name": "Mr. Peter Adrain J Van der Made M.Sc.", "title": "Founder, Member of Scientific Advisory Board & Non-Executive Director", "fiscalYear": 2025, "totalPay": 65259, "exercisedValue": 0, "unexercisedValue": 0}, {"maxAge": 1, "name": "Mr. Ken  Scarince", "title": "Chief Financial Officer", "fiscalYear": 2025, "totalPay": 472543, "exercisedValue": 0, "unexercisedValue": 0}, {"maxAge": 1, "name": "Dr. M. Anthony Lewis", "title": "Chief Technology Officer", "fiscalYear": 2025, "exercisedValue": 0, "unexercisedValue": 0}, {"maxAge": 1, "name": "Mr. Steven  Brightfield", "title": "Chief Marketing Officer", "fiscalYear": 2025, "exercisedValue": 0, "unexercisedValue": 0}, {"maxAge": 1, "name": "Mr. James  Shields", "title": "Vice President of Sales & Business Development", "fiscalYear": 2025, "exercisedValue": 0, "unexercisedValue": 0}, {"maxAge": 1, "name": "Dr. Jonathan  Tapson", "title": "Chief Development Officer", "fiscalYear": 2025, "exercisedValue": 0, "unexercisedValue": 0}, {"maxAge": 1, "name": "Ms. Kim  Larkin", "age": 56, "title": "Company Secretary", "yearBorn": 1969, "fiscalYear": 2025, "exercisedValue": 0, "unexercisedValue": 0}], "auditRisk": 9, "boardRisk": 2, "compensationRisk": 8, "shareHolderRightsRisk": 6, "overallRisk": 4, "governanceEpochDate": 1777593600, "compensationAsOfEpochDate": 1767139200, "executiveTeam": [], "maxAge": 86400, "priceHin