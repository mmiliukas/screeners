[{"address1": "301 Commerce Street", "address2": "Suite 1700", "city": "Fort Worth", "state": "TX", "zip": "76102", "country": "United States", "phone": "888 611 9888", "website": "https://distributionsolutionsgroup.com", "industry": "Industrial Distribution", "industryKey": "industrial-distribution", "industryDisp": "Industrial Distribution", "sector": "Industrials", "sectorKey": "industrials", "sectorDisp": "Industrials", "longBusinessSummary": "Distribution Solutions Group, Inc., a specialty distribution company, provides value-added distribution solutions to the maintenance, repair and operations (MRO), original equipment manufacturer, and industrial technology markets. It operates through four segments: Lawson, TestEquity, Gexpro Services, and Canada Branch Division. The Lawson segment distributes specialty products and services to the industrial, commercial, institutional, and government MRO marketplace. The TestEquity segment distributes test and measurement equipment and solutions, industrial and electronic production supplies, and vendor managed inventory programs, as well as converting, fabrication, and adhesive solutions to the aerospace and defense, wireless and communication, semiconductors, industrial electronics and automotive, and electronics manufacturing industries under the TestEquity, Hisco, Techni-Pro, Techni-Tool, and Jensen Tools brands. The Gexpro Services segment provides supply chain management solutions that offer VMI, kitting, global logistics management, manufacturing localization and import expertise, value engineering and quality assurance to renewables, industrial power, consumer and industrial, technology, transportation, and aerospace and defense. The Canada Branch Division distributes industrial MRO supplies, safety products, fasteners, power tools, and related value-add services to the industrial, government, commercial, and residential contractor markets for the Canadian MRO market. The company distributes MRO products to its customers through a network of sales representatives. It has operations in the United States, Canada, Europe, Pacific Rim, Latin America, and internationally. The company was formerly known as Lawson Products, Inc. and has changed to Distribution Solutions Group, Inc. 2022. Distribution Solutions Group, Inc. was incorporated in 1952 and is headquartered in Fort Worth, Texas.", "fullTimeEmployees": 4300, "companyOfficers": [{"maxAge": 1, "name": "Mr. John Bryan King C.F.A.", "age": 54, "title": "President, CEO & Chairman", "yearBorn": 1971, "fiscalYear": 2025, "exercisedValue": 0, "unexercisedValue": 0}, {"maxAge": 1, "name": "Mr. Ronald J. Knutson CPA", "age": 61, "title": "Executive VP, CFO & Treasurer", "yearBorn": 1964, "fiscalYear": 2025, "totalPay": 636257, "exercisedValue": 0, "unexercisedValue": 121612}, {"maxAge": 1, "name": "Mr. Cesar A. Lanuza", "age": 53, "title": "President & CEO of Lawson Products", "yearBorn": 1972, "fiscalYear": 2025, "totalPay": 772839, "exercisedValue": 0, "unexercisedValue": 0}, {"maxAge": 1, "name": "Mr. Robert H. Connors", "age": 60, "title": "President & CEO of Gexpro Services", "yearBorn": 1965, "fiscalYear": 2025, "totalPay": 689546, "exercisedValue": 0, "unexercisedValue": 0}, {"maxAge": 1, "name": "Mr. Barry  Litwin", "age": 58, "title": "Chief Executive Officer of Test Equity", "yearBorn": 1967, "fiscalYear": 2025, "totalPay": 767884, "exercisedValue": 0, "unexercisedValue": 0}, {"maxAge": 1, "name": "Mr. David S. Lambert", "age": 50, "title": "Chief Accounting Officer, VP & Controller", "yearBorn": 1975, "fiscalYear": 2025, "exercisedValue": 0, "unexercisedValue": 0}, {"maxAge": 1, "name": "Mr. Richard D. Pufpaf", "title": "Senior VP, Secretary, General Counsel & Chief Compliance Officer", "fiscalYear": 2025, "exercisedValue": 0, "unexercisedValue": 0}, {"maxAge": 1, "name": "Mr. Matthew J. Brown", "age": 61, "title": "Senior Vice President of Sales", "yearBorn": 1964, "fiscalYear": 2025, "exercisedValue": 0, "unexercisedValu