[{"address1": "12755 E. Nine Mile Road", "city": "Warren", "state": "MI", "zip": "48089", "country": "United States", "phone": "586 920 0100", "website": "https://www.universallogistics.com", "industry": "Trucking", "industryKey": "trucking", "industryDisp": "Trucking", "sector": "Industrials", "sectorKey": "industrials", "sectorDisp": "Industrials", "longBusinessSummary": "Universal Logistics Holdings, Inc. provides customized transportation and logistics solutions in the United States, Mexico, Canada, and Colombia. It operates through three segments: Contract Logistics, Intermodal, and Trucking. The Contract Logistics segment offers value-added and dedicated transportation services to support inbound logistics and industrial manufacturers and major retailers, including material handling, consolidation, sequencing, sub-assembly, cross-dock services, kitting, repacking, warehousing, returnable container management, and rail lift services. This segment also provides dedicated services which involve short-haul or round-trip moves within a defined geographic area provided through a network of union and non-union employee drivers, owner-operators, and contract drivers. The Intermodal segment offers local and regional drayage services through company-managed terminals using a combination of owner-operators, company equipment, and third-party capacity providers comprising steamship-truck, rail-truck, and support services. The Trucking segment engages in dry van, flatbed, heavy-haul and refrigerated operations for transporting various general commodities, such as automotive parts, machinery, building materials, paper, food, consumer goods, furniture, steel, other metals, and other industrial and consumer goods. The company is also involved in brokerage activities, as well as provision of support services. It serves automotive, retail and consumer goods, metals, and energy and manufacturing industries. The company was formerly known as Universal Truckload Services, Inc. and changed its name to Universal Logistics Holdings, Inc. in April 2016. Universal Logistics Holdings, Inc. was founded in 1981 and is headquartered in Warren, Michigan.", "fullTimeEmployees": 10525, "companyOfficers": [{"maxAge": 1, "name": "Mr. Timothy  Phillips", "age": 59, "title": "CEO, President & Director", "yearBorn": 1966, "fiscalYear": 2025, "totalPay": 1018791, "exercisedValue": 0, "unexercisedValue": 0}, {"maxAge": 1, "name": "Mr. Michael H. Rogers", "title": "CFO & Treasurer", "fiscalYear": 2025, "exercisedValue": 0, "unexercisedValue": 0}, {"maxAge": 1, "name": "Mr. Steven A. Fitzpatrick", "title": "VP of Finance & Investor Relations and Secretary", "fiscalYear": 2025, "exercisedValue": 0, "unexercisedValue": 0}], "auditRisk": 10, "boardRisk": 10, "compensationRisk": 6, "shareHolderRightsRisk": 6, "overallRisk": 10, "governanceEpochDate": 1782864000, "compensationAsOfEpochDate": 1767139200, "executiveTeam": [], "maxAge": 86400, "priceHint": 2, "previousClose": 14.74, "open": 14.58, "dayLow": 14.11, "dayHigh": 14.63, "regularMarketPreviousClose": 14.74, "regularMarketOpen": 14.58, "regularMarketDayLow": 14.11, "regularMarketDayHigh": 14.63, "dividendRate": 0.42, "dividendYield": 2.93, "exDividendDate": 1780272000, "payoutRatio": 0.18180001, "fiveYearAvgDividendYield": 1.62, "beta": 0.687, "forwardPE": 12.990909, "volume": 27568, "regularMarketVolume": 27568, "averageVolume": 72553, "averageVolume10days": 36260, "averageDailyVolume10Day": 36260, "bid": 10.44, "ask": 18.25, "bidSize": 2, "askSize": 2, "marketCap": 376822912, "nonDilutedMarketCap": 377482126, "fiftyTwoWeekLow": 11.73, "fiftyTwoWeekHigh": 30.76, "allTimeHigh": 53.29, "allTimeLow": 10.07, "priceToSalesTrailing12Months": 0.24412239, "fiftyDayAverage": 15.0148, "twoHundredDayAverage": 17.1179, "trailingAnnualDividendRate": 0.42, "trailingAnnualDividendYield": 0.028493894, "currency": "USD", "tradeable": false, "enterpriseValue": 1289551872, "profitMargins": -0.07087, "floatShares": 6700538, "sha