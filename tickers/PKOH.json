[{"address1": "6065 Parkland Boulevard", "city": "Cleveland", "state": "OH", "zip": "44124", "country": "United States", "phone": "440 947 2000", "fax": "440 947 2099", "website": "https://pkoh.com", "industry": "Specialty Industrial Machinery", "industryKey": "specialty-industrial-machinery", "industryDisp": "Specialty Industrial Machinery", "sector": "Industrials", "sectorKey": "industrials", "sectorDisp": "Industrials", "longBusinessSummary": "Park-Ohio Holdings Corp. provides supply chain management outsourcing services, capital equipment, and manufactured components in the United States, Europe, Asia, Mexico, Canada, and internationally. The company operates through three segments: Supply Technologies, Assembly Components, and Engineered Products. The Supply Technologies segment offers Total Supply Management, a solution that manages aspects of supplying production parts and materials, such as engineering and design support, part usage and cost analysis, supplier selection, quality assurance, bar coding, product packaging and tracking, just-in-time and point-of-use delivery, electronic billing services, and ongoing technical support. This segment also provides production components including valves, fuel hose assemblies, electro-mechanical hardware, labels, fittings, and steering components; and precision cold-formed and cold-extruded fasteners, and locknuts, as well as nuts, bolts, and wheel hardware under the SPAC brand. The Assembly Components segment offers high pressure direct fuel injection fuel rails and pipes; fuel filler pipes; plastic and rubber assemblies; Turbo Charging and Turbo Coolant hoses; and value-added services such as design engineering, machining, and parts assembly. The Engineered Products segment provides induction heating and melting systems, pipe threading systems, and forged and machined products for the ferrous and non-ferrous metals, silicon, coatings, forging, foundry, automotive, and construction equipment industries; and field services. This segment also engineers and installs mechanical forging presses; sells spare parts; machine, induction harden, and surface finish crankshafts and camshafts for use in locomotives; and forge aerospace and defense structural components comprising landing gears and struts, and railcar center plate and draft lug rail products. Park-Ohio Holdings Corp. was founded in 1907 and is headquartered in Cleveland, Ohio.", "companyOfficers": [{"maxAge": 1, "name": "Mr. Matthew V. Crawford", "age": 55, "title": "Chairman, CEO & President", "yearBorn": 1970, "fiscalYear": 2024, "totalPay": 3589059, "exercisedValue": 0, "unexercisedValue": 0}, {"maxAge": 1, "name": "Mr. Patrick W. Fogarty", "age": 64, "title": "VP & CFO", "yearBorn": 1961, "fiscalYear": 2024, "totalPay": 1201198, "exercisedValue": 0, "unexercisedValue": 0}, {"maxAge": 1, "name": "Mr. Robert D. Vilsack", "age": 64, "title": "Chief Legal & Administrative Officer and Corporate Secretary", "yearBorn": 1961, "fiscalYear": 2024, "totalPay": 1057164, "exercisedValue": 0, "unexercisedValue": 0}], "auditRisk": 8, "boardRisk": 8, "compensationRisk": 5, "shareHolderRightsRisk": 9, "overallRisk": 7, "governanceEpochDate": 1772323200, "compensationAsOfEpochDate": 1735603200, "executiveTeam": [], "maxAge": 86400, "priceHint": 2, "previousClose": 27.82, "open": 27.35, "dayLow": 25.29, "dayHigh": 27.35, "regularMarketPreviousClose": 27.82, "regularMarketOpen": 27.35, "regularMarketDayLow": 25.29, "regularMarketDayHigh": 27.35, "dividendRate": 0.5, "dividendYield": 1.95, "exDividendDate": 1770336000, "payoutRatio": 0.2439, "fiveYearAvgDividendYield": 2.49, "beta": 1.127, "trailingPE": 12.482927, "forwardPE": 7.3114285, "volume": 38282, "regularMarketVolume": 38282, "averageVolume": 30244, "averageVolume10days": 32240, "averageDailyVolume10Day": 32240, "bid": 25.14, "ask": 32.4, "bidSize": 2, "askSize": 2, "marketCap": 368603648, "nonDilutedMarketCap": 368603657, "fiftyTwoWeekLow": 15.52, "fiftyTwoWeekHigh": 29.5, "allTim