[{"address1": "105 Edgeview Drive", "address2": "Suite 425", "city": "Broomfield", "state": "CO", "zip": "80021", "country": "United States", "phone": "646 827 4366", "website": "https://www.digitalocean.com", "industry": "Software - Infrastructure", "industryKey": "software-infrastructure", "industryDisp": "Software - Infrastructure", "sector": "Technology", "sectorKey": "technology", "sectorDisp": "Technology", "longBusinessSummary": "DigitalOcean Holdings, Inc., through its subsidiaries, operates an agentic inference cloud platform in North America, Europe, Asia, and internationally. The company provides AI and Digital Native Enterprises build, run, and scale intelligent applications for growing technology companies. It also offers infrastructure-as-a-service (IaaS) solutions comprising compute, storage, and networking products, including cloud firewalls, managed load balancers, NAT gateways, and virtual private cloud software, as well as IP address management and domain name system management. In addition, the company provides platform-as-a-service (PaaS) and software-as-a-service (SaaS) solutions, such as managed databases; managed Kubernetes and container registry; application platform to build, deploy, and scale applications; Functions, a serverless compute solution; and Uptime for real-time uptime and latency alerts, as well as managed hosting and DigitalOcean Marketplace, a platform where developers can find pre-configured applications and solutions. Further, it offers artificial intelligence (AI)/machine learning (ML) applications comprising GPU droplets; bare metal GPUS, which provides access to a GPU server without any virtualization layer and gives developers with customizable server for their use case; and Jupyter Notebooks that provides cloud workspace and managed interactive development environment for exploring data and training, and building machine learning models. Its customers use its platform in various industry verticals, such as online gaming, fintech, and cybersecurity, as well as for a range of use cases, including building and hosting websites, web and mobile applications development, AI integration, and building AI products and applications. DigitalOcean Holdings, Inc. was incorporated in 2012 and is headquartered in Broomfield, Colorado.", "fullTimeEmployees": 1462, "companyOfficers": [{"maxAge": 1, "name": "Mr. Padmanabhan T. Srinivasan", "age": 49, "title": "CEO & Director", "yearBorn": 1976, "fiscalYear": 2025, "totalPay": 1210795, "exercisedValue": 0, "unexercisedValue": 0}, {"maxAge": 1, "name": "Mr. W. Matthew Steinfort", "age": 55, "title": "Chief Financial Officer", "yearBorn": 1970, "fiscalYear": 2025, "totalPay": 985154, "exercisedValue": 0, "unexercisedValue": 0}, {"maxAge": 1, "name": "Ms. Cherie  Barrett", "age": 52, "title": "Senior VP & Chief Accounting Officer", "yearBorn": 1973, "fiscalYear": 2025, "exercisedValue": 0, "unexercisedValue": 0}, {"maxAge": 1, "name": "Mr. Vinay S. Kumar", "age": 46, "title": "Chief Product and Technology Officer", "yearBorn": 1979, "fiscalYear": 2025, "exercisedValue": 0, "unexercisedValue": 0}, {"maxAge": 1, "name": "Mr. Brady  Mickelsen J.D.", "age": 54, "title": "Chief Legal & Administrative Officer", "yearBorn": 1971, "fiscalYear": 2025, "exercisedValue": 0, "unexercisedValue": 0}, {"maxAge": 1, "name": "Mr. Leo  Leung", "title": "Chief Marketing Officer", "fiscalYear": 2025, "exercisedValue": 0, "unexercisedValue": 0}, {"maxAge": 1, "name": "Mr. Kevin Van Gundy", "title": "Chief Revenue Officer", "fiscalYear": 2025, "exercisedValue": 0, "unexercisedValue": 0}, {"maxAge": 1, "name": "Mr. Alan  Shapiro J.D.", "age": 56, "title": "General Counsel & Secretary", "yearBorn": 1969, "fiscalYear": 2025, "totalPay": 664537, "exercisedValue": 0, "unexercisedValue": 20252508}], "auditRisk": 2, "boardRisk": 9, "compensationRisk": 7, "shareHolderRightsRisk": 8, "overallRisk": 8, "governanceEpochDate": 1782864000, "compensationAsOfEpochDate": 1767139200, "execu