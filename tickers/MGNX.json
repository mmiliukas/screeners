[{"address1": "9704 Medical Center Drive", "city": "Rockville", "state": "MD", "zip": "20850", "country": "United States", "phone": "301 251 5172", "fax": "301 251 5321", "website": "https://www.macrogenics.com", "industry": "Biotechnology", "industryKey": "biotechnology", "industryDisp": "Biotechnology", "sector": "Healthcare", "sectorKey": "healthcare", "sectorDisp": "Healthcare", "longBusinessSummary": "MacroGenics, Inc., a clinical-stage biopharmaceutical company, discovers, develops, manufactures, and commercializes antibody-based therapeutics for the treatment of cancer in the United States. The company's product pipeline includes lorigerlimab, a bispecific DART molecule that targets checkpoint inhibitors PD-1 and CTLA-4 for the treatment of mCRPC and docetaxel that is in phase 2 clinical trials, as well as for the treatment of platinum-resistant ovarian cancer and clear cell gynecologic cancer which has completed phase 1 clinical trial; MGC026, an ADC that targets B7-H3 and delivers a novel topoisomerase I inhibitor (TOP1i)-based linker-payload; MGC028, an antibody-drug conjugates (ADC) that targets ADAM9 and delivers a novel TOP1i-based linker-payload for the treatment of solid tumors, which is in phase 1 clinical trials; MGC030, a ADC molecule that targets an undisclosed antigen expressed across several solid tumors, which is in preclinical trials. It is also developing T-cell engager programs. The company has collaborations with TerSera Therapeutics LLC; Incyte Corporation; and Gilead Sciences, Inc. MacroGenics, Inc. was incorporated in 2000 and is headquartered in Rockville, Maryland.", "fullTimeEmployees": 293, "companyOfficers": [{"maxAge": 1, "name": "Mr. Eric Blasius Risser", "age": 52, "title": "CEO, President & Director", "yearBorn": 1973, "fiscalYear": 2025, "totalPay": 977468, "exercisedValue": 0, "unexercisedValue": 0}, {"maxAge": 1, "name": "Mr. James  Karrels", "age": 58, "title": "Senior VP & CFO", "yearBorn": 1967, "fiscalYear": 2025, "totalP