[{"address1": "189 Glencoe Drive", "city": "Mount Pearl", "state": "NF", "zip": "A1N 4P6", "country": "Canada", "phone": "709-757-5757", "website": "https://krakenrobotics.com", "industry": "Scientific & Technical Instruments", "industryKey": "scientific-technical-instruments", "industryDisp": "Scientific & Technical Instruments", "sector": "Technology", "sectorKey": "technology", "sectorDisp": "Technology", "longBusinessSummary": "Kraken Robotics Inc., a marine technology company, engages in the design, manufacture, and sale of sonar and optical sensors, batteries, and underwater robotic equipment for unmanned underwater vehicles. It operates in two segments, Products and Services. The company offers AquaPix miniature interferometric synthetic aperture sonar (MINSAS), a configurable MINSAS; and SeaPower, a pressure tolerant deep sea battery. It also provides Kraken Active Towed Fish, a towed underwater vehicle for seabed mapping; LARS, an autonomous launch and recovery system that enable an unmanned vehicle and its payloads to be brought aboard to a host ship; Acoustic Core that provides a 3D image of stratigraphy layers and anomalies across the entire foundation footprint; and Sub-Bottom Imager used to view image beneath the seabed. In addition, the company designs and manufactures pressure tolerant batteries, battery management systems, and electronics; and robotics as a service. The company's products are used in military and commercial applications in Canada, the Asia Pacific, Europe, the Middle East, Africa, North America, and internationally. The company was formerly known as Kraken Sonar Inc. and changed its name to Kraken Robotics Inc. in September 2017. Kraken Robotics Inc. is headquartered in Mount Pearl, Canada.", "fullTimeEmployees": 433, "companyOfficers": [{"maxAge": 1, "name": "Mr. Greg  Reid C.A., CPA", "title": "CEO, President & Director", "fiscalYear": 2024, "totalPay": 468191, "exercisedValue": 0, "unexercisedValue": 0}, {"maxAge": 1, "name": "Mr