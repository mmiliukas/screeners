ers, designs, fabricates, constructs, commissions, operates, and services hydrocarbon processing equipment. Additionally, it provides field construction, installation, and commissioning for an integrated electric power solution, as well as re-engineering and refurbishment services. The company was formerly known as Enerflex Systems Income Fund and changed its name to Enerflex Ltd. in January 2010. Enerflex Ltd. was founded in 1980 and is headquartered in Calgary, Canada.", "fullTimeEmployees": 4554, "companyOfficers": [], "auditRisk": 10, "boardRisk": 4, "compensationRisk": 10, "shareHolderRightsRisk": 6, "overallRisk": 8, "governanceEpochDate": 1775001600, "executiveTeam": [], "maxAge": 86400, "priceHint": 2, "previousClose": 21.08, "open": 20.87, "dayLow": 20.89, "dayHigh": 21.45, "regularMarketPreviousClose": 21.08, "regularMarketOpen": 20.87, "regularMarketDayLow": 20.89, "regularMarketDayHigh": 21.45, "dividendRate": 0.12, "dividendYield": 0.54, "exDividendDate": 1773187200, "payoutRatio": 0.21370001, "beta": 2.012, "trailingPE": 41.19231, "forwardPE": 14.137774, "volume": 199422, "regularMarketVolume": 199422, "averageVolume": 647937, "averageVolume10days": 906570, "averageDailyVolume10Day": 906570, "bid": 20.17, "ask": 22.29, "bidSize": 200, "askSize": 500, "marketCap": 2608994048, "nonDilutedMarketCap": 2611510777, "fiftyTwoWeekLow": 6.36, "fiftyTwoWeekHigh": 23.82, "allTimeHigh": 23.82, "allTimeLow": 3.0, "priceToSalesTrailing12Months": 1.0147779, "fiftyDayAverage": 20.3864, "twoHundredDayAverage": 13.9272, "trailingAnnualDividendRate": 0.117, "trailingAnnualDividendYield": 0.0055502844, "currency": "USD", "tradeable": false, "enterpriseValue": 3181993984, "profitMargins": 0.02489, "floatShares": 121122125, "sharesOutstanding": 121801779, "sharesShort": 426369, "sharesShortPriorMonth": 202469, "sharesShortPreviousMonthDate": 1690761600, "dateShortInterest": 1772150400, "sharesPercentSharesOut": 0.0047999998, "heldPercentInsiders": 0.00822, "heldPercentInsti