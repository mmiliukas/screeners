[{"address1": "108 Patriot Drive", "address2": "Suite A", "city": "Middletown", "state": "DE", "zip": "19709", "country": "United States", "phone": "302 274 8744", "website": "https://www.zymeworks.com", "industry": "Biotechnology", "industryKey": "biotechnology", "industryDisp": "Biotechnology", "sector": "Healthcare", "sectorKey": "healthcare", "sectorDisp": "Healthcare", "longBusinessSummary": "Zymeworks Inc., a biotechnology company, develops biotherapeutics for the treatment of cancer, inflammation, and autoimmune diseases. The company's platforms include Azymetric multispecific antibody platform; Drug Conjugate platform that includes a suite of proprietary cytotoxins comprising topoisomerase and microtubulin inhibiting toxins, stable linkers, and conjugation technologies; EFECT platform, which consists of a set of modifications to the Fc region of antibodies; and ProTECT, a tumor-specific immune co-stimulation platform. Its lead product candidates include Ziihera (zanidatamab-hrii), a bispecific antibody targeting HER2-expressing tumors; zanidatamab for the treatment of neoadjuvant populations, breast cancer, and other HER2-expressing cancers; Pasritamig, a bispecific T cell engager targeting human kallikrein 2 for the treatment monotherapy and castration resistant prostate cancer; ZW191, a clinical- antibody-drug conjugates (ADC) that targets folate receptor alpha expressing tumors, including ovarian, endometrial, and non-small cell lung cancers; ZW251, a clinical-stage ADC molecule for the treatment of glypican 3 expressing hepatocellular carcinoma; ZW220, an ADC that targets NaPi2b-expressing NSCLC and ovarian cancer; ZW209, a novel TriTCE targeting Delta-like ligand 3 -expressing tumor cells for the treatment of solid tumors; and ZW1528, a bispecific molecule to treat chronic obstructive pulmonary disease. It has strategic partnerships and collaborations with Jazz Pharmaceuticals plc; Bristol- Myers Squibb company; Celgene Alpine Investment Co. LLC; GlaxoSmithKline Intellectual Property Development Limited; Daiichi Sankyo Co., Ltd.; Merck Sharp & Dohme Research GmbH; and Janssen Biotech, Inc. Zymeworks Inc. was incorporated in 2003 and is based in Middletown, Delaware.", "fullTimeEmployees": 243, "companyOfficers": [{"maxAge": 1, "name": "Mr. Kenneth H. Galbraith C.A.", "age": 63, "title": "Chairman of the Board, CEO & President", "yearBorn": 1962, "fiscalYear": 2025, "totalPay": 1708375, "exercisedValue": 0, "unexercisedValue": 11001213}, {"maxAge": 1, "name": "Dr. Paul A. Moore Ph.D.", "age": 58, "title": "Chief Scientific Officer", "yearBorn": 1967, "fiscalYear": 2025, "totalPay": 998368, "exercisedValue": 0, "unexercisedValue": 5364331}, {"maxAge": 1, "name": "Mr. Scott  Platshon B.S.", "age": 34, "title": "Executive VP & Chief Business Officer", "yearBorn": 1991, "fiscalYear": 2025, "exercisedValue": 0, "unexercisedValue": 0}, {"maxAge": 1, "name": "Ms. Kristin  Stafford CPA", "age": 43, "title": "Executive VP & CFO", "yearBorn": 1982, "fiscalYear": 2025, "exercisedValue": 0, "unexercisedValue": 0}, {"maxAge": 1, "name": "Mr. Mark  Hollywood", "age": 56, "title": "Executive VP & COO", "yearBorn": 1969, "fiscalYear": 2025, "exercisedValue": 0, "unexercisedValue": 0}, {"maxAge": 1, "name": "Ms. Shrinal  Inamdar B.Sc.", "title": "Vice President of Investor Relations", "fiscalYear": 2025, "exercisedValue": 0, "unexercisedValue": 0}, {"maxAge": 1, "name": "Mr. Paul R. Schneider", "age": 54, "title": "Executive VP & General Counsel", "yearBorn": 1971, "fiscalYear": 2025, "exercisedValue": 0, "unexercisedValue": 0}, {"maxAge": 1, "name": "Ms. Diana  Papove B.Com.", "title": "Vice President of Corporate Communications", "fiscalYear": 2025, "exercisedValue": 0, "unexercisedValue": 0}, {"maxAge": 1, "name": "Dr. Lindsey  Foulkes B.Sc., Ph.D.", "title": "Senior Vice President of Corporate Development & Strategy", "fiscalYear": 2025, "exercisedValue": 0, "unexercisedValue": 0}, {"maxAge": 1, "name": "Ms. Laura  O'Connor", "