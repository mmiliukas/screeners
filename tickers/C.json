 product offerings; professional industries, including law firms, consulting groups, accounting, and asset management; and affluent and high net worth clients. The company operates in North America, the United Kingdom, Japan, North and South Asia, Australia, Europe, the Middle East, and Africa. Citigroup Inc. was founded in 1812 and is headquartered in New York, New York.", "fullTimeEmployees": 224000, "companyOfficers": [], "auditRisk": 1, "boardRisk": 5, "compensationRisk": 7, "shareHolderRightsRisk": 1, "overallRisk": 2, "governanceEpochDate": 1777593600, "irWebsite": "http://www.citigroup.com/citi/investor/overview.html", "executiveTeam": [], "maxAge": 86400, "priceHint": 2, "previousClose": 124.68, "open": 124.65, "dayLow": 123.5201, "dayHigh": 126.84, "regularMarketPreviousClose": 124.68, "regularMarketOpen": 124.65, "regularMarketDayLow": 123.5201, "regularMarketDayHigh": 126.84, "dividendRate": 2.4, "dividendYield": 1.91, "exDividendDate": 1777852800, "payoutRatio": 0.2917, "fiveYearAvgDividendYield": 3.42, "beta": 1.124, "trailingPE": 15.543209, "forwardPE": 10.048447, "volume": 7637801, "regularMarketVolume": 7637801, "averageVolume": 12921742, "averageVolume10days": 9444490, "averageDailyVolume10Day": 9444490, "bid": 125.0, "ask": 125.97, "bidSize": 300, "askSize": 200, "marketCap": 214732144640, "nonDilutedMarketCap": 214732138634, "fiftyTwoWeekLow": 74.3, "fiftyTwoWeekHigh": 135.29, "allTimeHigh": 591.25, "allTimeLow": 9.7, "priceToSalesTrailing12Months": 2.7273116, "fiftyDayAverage": 123.1822, "twoHundredDayAverage": 110.4116, "trailingAnnualDividendRate": 2.36, "trailingAnnualDividendYield": 0.018928455, "currency": "USD", "tradeable": false, "enterpriseValue": 4900138496, "profitMargins": 0.20356001, "floatShares": 1700067941, "sharesOutstanding": 1705576955, "sharesShort": 424076, "sharesShortPriorMonth": 333507, "sharesShortPreviousMonthDate": 1776211200, "dateShortInterest": 1778803200, "sharesPercentSharesOut": 0.0002, "heldPercentInsiders": 0.00