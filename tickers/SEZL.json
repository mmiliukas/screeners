[{"address1": "700 Nicollet Mall", "address2": "Suite 640", "city": "Minneapolis", "state": "MN", "zip": "55402", "country": "United States", "phone": "651 240 6001", "website": "https://www.sezzle.com", "industry": "Credit Services", "industryKey": "credit-services", "industryDisp": "Credit Services", "sector": "Financial Services", "sectorKey": "financial-services", "sectorDisp": "Financial Services", "longBusinessSummary": "Sezzle Inc. operates as a technology-enabled payments company primarily in the United States and Canada. The company provides Sezzle Platform that provides a payments solution for consumers that extends credit at the point-of-sale allowing consumers to purchase and receive the ordered merchandise at the time of sale while paying in installments over time; Pay-in-Four, which allows consumers to pay a fourth of the purchase price up front and then another fourth of the purchase price every two weeks thereafter over a total of six weeks; Pay-in-Full that allows consumers to pay for the full value of their order up-front through the Sezzle Platform without the extension of credit; and Pay-in-Two and other alternative installment options, which allow consumer to pay half of the value of their order up-front and the second half in two weeks. It also offers Sezzle Virtual Card that allows consumers to access the Sezzle Platform in the form of merchants in-store and online with merchants that are not directly integrated with Sezzle; Sezzle Anywhere, a paid subscription service that allows consumers to use their Sezzle Virtual Card at any merchant online or in-store; Sezzle On-Demand, a service that allows consumers who are not subscribed to Sezzle Anywhere to use the Sezzle Platform at any merchant online or in-store; Sezzle Premium, a paid subscription service that allows its consumers to access large, non-integrated premium merchants; and Sezzle Up, an opt-in feature of the Sezzle Platform. In addition, the company provides Long-Term Lending through collaboration with third-party lenders and Product Innovation. Sezzle Inc. was incorporated in 2016 and is headquartered in Minneapolis, Minnesota.", "fullTimeEmployees": 201, "companyOfficers": [{"maxAge": 1, "name": "Mr. Charles G. Youakim", "age": 48, "title": "Co-Founder, Executive Chairman & CEO", "yearBorn": 1977, "fiscalYear": 2024, "totalPay": 1077551, "exercisedValue": 0, "unexercisedValue": 2946037}, {"maxAge": 1, "name": "Mr. Paul Victor Paradis", "age": 41, "title": "Co-Founder, President & Executive Director", "yearBorn": 1984, "fiscalYear": 2024, "totalPay": 657735, "exercisedValue": 0, "unexercisedValue": 2946037}, {"maxAge": 1, "name": "Mr. Lee Dickson Brading C.F.A.", "title": "Chief Financial Officer", "fiscalYear": 2024, "exercisedValue": 0, "unexercisedValue": 0}, {"maxAge": 1, "name": "Mr. Amin  Sabzivand", "age": 36, "title": "Chief Operating Officer", "yearBorn": 1989, "fiscalYear": 2024, "exercisedValue": 0, "unexercisedValue": 0}, {"maxAge": 1, "name": "Kerissa  Hollis", "title": "General Counsel & Corporate Secretary", "fiscalYear": 2024, "exercisedValue": 0, "unexercisedValue": 0}, {"maxAge": 1, "name": "Justin  Krause", "title": "Senior VP of Finance & Financial Controller", "fiscalYear": 2024, "exercisedValue": 0, "unexercisedValue": 0}], "auditRisk": 5, "boardRisk": 9, "compensationRisk": 8, "shareHolderRightsRisk": 2, "overallRisk": 6, "governanceEpochDate": 1772323200, "compensationAsOfEpochDate": 1735603200, "executiveTeam": [], "maxAge": 86400, "priceHint": 2, "previousClose": 75.77, "open": 73.19, "dayLow": 71.5, "dayHigh": 74.99, "regularMarketPreviousClose": 75.77, "regularMarketOpen": 73.19, "regularMarketDayLow": 71.5, "regularMarketDayHigh": 74.99, "payoutRatio": 0.0, "beta": 8.617, "trailingPE": 19.75, "forwardPE": 12.674519, "volume": 535969, "regularMarketVolume": 535969, "averageVolume": 896252, "averageVolume10days": 1266710, "averageDailyVolume10Day": 1266710, "bid": 53.59, "ask": 92.92, "bidSize": 2, "askSize": 2, "mar