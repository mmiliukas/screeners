, Japan.", "fullTimeEmployees": 16542, "companyOfficers": [{"maxAge": 1, "name": "Mr. Takahisa  Takahara", "age": 64, "title": "Chairman, President & CEO", "yearBorn": 1961, "fiscalYear": 2025, "totalPay": 1607499, "exercisedValue": 0, "unexercisedValue": 0}, {"maxAge": 1, "name": "Mr. Hirotatsu  Shimada", "title": "Senior Managing Executive Officer and Head of Accounting & Finance Division", "fiscalYear": 2025, "exercisedValue": 0, "unexercisedValue": 0}, {"maxAge": 1, "name": "Kazuya  Kondo", "title": "Investor Relations Office Department Manager", "fiscalYear": 2025, "exercisedValue": 0, "unexercisedValue": 0}, {"maxAge": 1, "name": "Mr. Kenji  Takaku", "age": 65, "title": "Senior Managing Exec Officer, Co-CMO, Marketing & Sales Manager and Director", "yearBorn": 1960, "fiscalYear": 2025, "exercisedValue": 0, "unexercisedValue": 0}, {"maxAge": 1, "name": "Mr. Tetsuya  Shite", "age": 63, "title": "Senior Executive Managing Exec Officer, Co-CIO, GM of Global HR & General Affairs Div and Director", "yearBorn": 1962, "fiscalYear": 2025, "exercisedValue": 0, "unexercisedValue": 0}, {"maxAge": 1, "name": "Mr. Tadashi  Nakai", "age": 62, "title": "Senior Managing Executive Officer", "yearBorn": 1963, "fiscalYear": 2025, "exercisedValue": 0, "unexercisedValue": 0}, {"maxAge": 1, "name": "Satoru  Kiuchi", "title": "Managing Executive Officer", "fiscalYear": 2025, "exercisedValue": 0, "unexercisedValue": 0}, {"maxAge": 1, "name": "Chikara  Oka", "title": "Managing Executive Officer", "fiscalYear": 2025, "exercisedValue": 0, "unexercisedValue": 0}, {"maxAge": 1, "name": "Tsutomu  Watanabe", "title": "Managing Executive Officer", "fiscalYear": 2025, "exercisedValue": 0, "unexercisedValue": 0}, {"maxAge": 1, "name": "Tsutomu  Kido", "title": "Senior Executive Officer", "fiscalYear": 2025, "exercisedValue": 0, "unexercisedValue": 0}], "auditRisk": 1, "boardRisk": 8, "compensationRisk": 1, "shareHolderRightsRisk": 8, "overallRisk": 6, "governanceEpochDate": 1782864000, "compens