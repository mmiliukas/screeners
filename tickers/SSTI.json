[{"address1": "39300 Civic Center Drive", "address2": "Suite 300", "city": "Fremont", "state": "CA", "zip": "94538", "country": "United States", "phone": "510 794 3100", "fax": "650 887 2106", "website": "https://soundthinking.com", "industry": "Software - Application", "industryKey": "software-application", "industryDisp": "Software - Application", "sector": "Technology", "sectorKey": "technology", "sectorDisp": "Technology", "longBusinessSummary": "SoundThinking, Inc., a public safety technology company, provides data-driven solutions and strategic advisory services for law enforcement, security teams, and civic leadership. Its SafetySmart platform that includes data-driven tools comprising ShotSpotter, an outdoor gunshot detection, location, and alerting system; CrimeTracer, an agency-wide crime data and intelligence platform that enables investigators, analysts, patrol officers and command staff to search through criminal justice records from across jurisdictions, leverage dashboards, and AI-assisted tools to generate tactical leads and make intelligent connections to solve cases; CaseBuilder, a one-stop investigative case management system for tracking, reporting and collaborating on cases; ResourceRouter, a software that directs the deployment of patrol and community anti-violence resources; PlateRanger powered by Rekor, an automatic license plate recognition and vehicle identification solution; and SafePointe, an artificial intelligence-based weapons detection system. The company also offers ShotSpotter for Campus and ShotSpotter for Corporate, to universities, corporate campuses, and key infrastructure centers to mitigate risk and enhance security by notifying authorities of outdoor gunfire incidents and saving critical minutes for first responders to arrive. In addition, it provides perimeter-based sniper gunshot detection solutions. The company sells its solutions through its direct sales teams. The company was formerly known as ShotSpotter, Inc. and changed its name to SoundThinking, Inc. in April 2023. SoundThinking, Inc. was founded in 1996 and is headquartered in Fremont, California.", "fullTimeEmployees": 302, "companyOfficers": [{"maxAge": 1, "name": "Mr. Ralph A. Clark", "age": 66, "title": "President, CEO & Director", "yearBorn": 1959, "fiscalYear": 2025, "totalPay": 781900, "exercisedValue": 0, "unexercisedValue": 89460}, {"maxAge": 1, "name": "Mr. Alan R. Stewart", "age": 61, "title": "CFO & Secretary", "yearBorn": 1964, "fiscalYear": 2025, "totalPay": 521445, "exercisedValue": 0, "unexercisedValue": 0}, {"maxAge": 1, "name": "Dr. Robert L. Showen Ph.D.", "title": "Founder & Chief Scientist", "fiscalYear": 2025, "exercisedValue": 0, "unexercisedValue": 0}, {"maxAge": 1, "name": "Mr. Jason  Dunham", "title": "Founder", "fiscalYear": 2025, "exercisedValue": 0, "unexercisedValue": 0}, {"maxAge": 1, "name": "Mr. Paul S. Ames", "age": 66, "title": "Senior Vice President of Products & Technology", "yearBorn": 1959, "fiscalYear": 2025, "totalPay": 220000, "exercisedValue": 0, "unexercisedValue": 0}, {"maxAge": 1, "name": "Mr. Robert Samuel Klepper", "age": 59, "title": "Senior VP of Product Management & Corporate Development", "yearBorn": 1966, "fiscalYear": 2025, "totalPay": 310600, "exercisedValue": 0, "unexercisedValue": 0}, {"maxAge": 1, "name": "Mr. Gregg  Makuch", "title": "Senior Vice President of Marketing", "fiscalYear": 2025, "exercisedValue": 0, "unexercisedValue": 0}, {"maxAge": 1, "name": "Mr. Kirk  Arthur", "age": 53, "title": "Senior Vice President of Global Sales", "yearBorn": 1972, "fiscalYear": 2025, "exercisedValue": 0, "unexercisedValue": 0}, {"maxAge": 1, "name": "Ms. Anne  Mueller", "title": "Senior Vice President of Human Resources", "fiscalYear": 2025, "exercisedValue": 0, "unexercisedValue": 0}, {"maxAge": 1, "name": "Mr. Larry  S. Jackson", "title": "Senior Vice President of Customer Success & Analytics", "fiscalYear": 2025, "exercisedValue": 0, "unexercisedValue": 0}], "auditRisk": 10, "