[{"address1": "2290 North 1st Street", "address2": "Suite 201", "city": "San Jose", "state": "CA", "zip": "95131", "country": "United States", "phone": "408 434 6040", "fax": "408 434 6050", "website": "https://www.gctsemi.com", "industry": "Semiconductors", "industryKey": "semiconductors", "industryDisp": "Semiconductors", "sector": "Technology", "sectorKey": "technology", "sectorDisp": "Technology", "longBusinessSummary": "GCT Semiconductor Holding, Inc., a fabless semiconductor company, designs, manufactures, and sells communication semiconductors for industrial, business-to-business, and consumer applications in the United States, Taiwan, China, Germany, and South Korea. The company offers wireless communication technologies, such as 5G/5.75G/4.5G/4G transceivers and modems; RF and modem chipsets based on fourth-generation (4G) long term evolution (LTE) technology, including 4G LTE, 4.5G LTE Advanced, and 4.75G LTE Advanced-Pro; baseband modem solutions, RF transceivers, and system-on-chip (SoC) solutions; and product design and support, warranty development, customer support, and technical support services. It also develops and sells cellular Internet of Things (IoT) chipsets for low-speed mobile networks, such as eMTC/NB-IOT/Sigfox, and other network protocols; and 5G NR chipsets and other 5G NR solutions. The company's products and solutions are used in portable wireless routers, indoor and outdoor fixed wireless routers, industrial machine-to-machine applications, smartphones, fixed wireless subscriber terminals, various communication modules and devices, and industrial products. It sells its products directly or indirectly through distributors to wireless operators, original equipment manufacturers (OEMs), and original design manufacturers (ODMs) in Taiwan, China, Korea, Japan, Europe, North America, and South America. GCT Semiconductor Holding, Inc. has strategic partnership with MaxLinear, Inc. to develop 5G fixed wireless access (FWA) gateways and converged gateways for consumer and enterprise applications. GCT Semiconductor Holding, Inc. was founded in 1998 and is headquartered in San Jose, California.", "fullTimeEmployees": 126, "companyOfficers": [{"maxAge": 1, "name": "Dr. Kyeongho  Lee Ph.D.", "age": 56, "title": "Co-Founder & Independent Chairman", "yearBorn": 1969, "fiscalYear": 2025, "totalPay": 55000, "exercisedValue": 0, "unexercisedValue": 0}, {"maxAge": 1, "name": "Mr. John Brian Schlaefer", "age": 61, "title": "President, CEO & Director", "yearBorn": 1964, "fiscalYear": 2025, "totalPay": 393111, "exercisedValue": 0, "unexercisedValue": 109162}, {"maxAge": 1, "name": "Mr. Fong Ting Cheng", "age": 63, "title": "Chief Financial Officer", "yearBorn": 1962, "fiscalYear": 2025, "totalPay": 296005, "exercisedValue": 0, "unexercisedValue": 0}, {"maxAge": 1, "name": "Mr. Alex  Sum", "age": 77, "title": "Senior Vice President of Sales & Marketing", "yearBorn": 1948, "fiscalYear": 2025, "totalPay": 312061, "exercisedValue": 0, "unexercisedValue": 40001}, {"maxAge": 1, "name": "Dr. Jeongmin  Kim Ph.D.", "age": 55, "title": "CTO & VP of Engineering", "yearBorn": 1970, "fiscalYear": 2025, "totalPay": 88211, "exercisedValue": 0, "unexercisedValue": 285450}], "compensationAsOfEpochDate": 1767139200, "executiveTeam": [], "maxAge": 86400, "priceHint": 4, "previousClose": 2.12, "open": 2.04, "dayLow": 1.97, "dayHigh": 2.13, "regularMarketPreviousClose": 2.12, "regularMarketOpen": 2.04, "regularMarketDayLow": 1.97, "regularMarketDayHigh": 2.13, "payoutRatio": 0.0, "beta": 1.778, "forwardPE": -59.999996, "volume": 1615413, "regularMarketVolume": 1615413, "averageVolume": 6235716, "averageVolume10days": 1784960, "averageDailyVolume10Day": 1784960, "bid": 2.09, "ask": 2.09, "bidSize": 2800, "askSize": 3600, "marketCap": 191022304, "nonDilutedMarketCap": 192841583, "fiftyTwoWeekLow": 0.955, "fiftyTwoWeekHigh": 3.93, "allTimeHigh": 56.0, "allTimeLow": 0.9, "priceToSalesTrailing12Months": 44.527344, "fiftyDayAverage": 2.5758, "