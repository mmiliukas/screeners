[{"address1": "511 West Freshwater Way", "city": "Milwaukee", "state": "WI", "zip": "53204", "country": "United States", "phone": "855 480 5050", "website": "https://www.zurnelkay.com", "industry": "Pollution & Treatment Controls", "industryKey": "pollution-treatment-controls", "industryDisp": "Pollution & Treatment Controls", "sector": "Industrials", "sectorKey": "industrials", "sectorDisp": "Industrials", "longBusinessSummary": "Zurn Elkay Water Solutions Corporation engages in design, procurement, manufacture, and marketing of water management solutions in the United States, Canada, and internationally. It offers water dispensing and filtration products, such as filtered bottle filling stations, water fountains and water dispensers, and filtered faucets under the Elkay and Halsey Taylor brand names; filtered units including water filters; and water safety and control products, such as backflow preventers, fire system valves, pressure reducing valves, and thermostatic mixing valves under the Zurn and Wilkins brand names. The company also provides flow systems products comprising point drains, hydrants, fixture carrier systems, and chemical drainage systems; and oil and grease interceptors and separators, acid neutralization systems, and remote monitoring systems under the Zurn, Green Turtle, and Wade brands. In addition, it offers sensor operated flush valves under the Aquaflush, AquaSense, and AquaVantage brands; heavy-duty commercial faucets under the AquaSpec brand; flush valves and faucets under the Hydro X Power brands; water conserving fixtures under the EcoVantage and Zurn One brands; stainless steel, quartz, fireclay-ceramic, and cast iron sinks under the Elkay brand name; stainless steel sinks and plumbing fixtures under the Just brand; restroom partition systems and lockers under the Hadrian brand name; and hand dryers. Further, the company offers its products to institutional, commercial, waterworks, and residential end markets through independent sales representatives, plumbing wholesalers, and industry-specific distributors in the waterworks, foodservice, industrial, janitorial, sanitation, and sitework industries. The company was formerly known as Zurn Water Solutions Corporation and changed its name to Zurn Elkay Water Solutions Corporation in July 2022. Zurn Elkay Water Solutions Corporation was founded in 1900 and is headquartered in Milwaukee, Wisconsin.", "fullTimeEmployees": 2600, "companyOfficers": [{"maxAge": 1, "name": "Mr. Todd A. Adams", "age": 54, "title": "CEO & Chairman", "yearBorn": 1971, "fiscalYear": 2025, "totalPay": 2956917, "exercisedValue": 0, "unexercisedValue": 0}, {"maxAge": 1, "name": "Mr. Jeffrey A. Schoon", "age": 42, "title": "President", "yearBorn": 1983, "fiscalYear": 2025, "totalPay": 1087384, "exercisedValue": 0, "unexercisedValue": 0}, {"maxAge": 1, "name": "Mr. David J. Pauli", "age": 43, "title": "Chief Operating Officer", "yearBorn": 1982, "fiscalYear": 2025, "totalPay": 1283748, "exercisedValue": 99424, "unexercisedValue": 753464}, {"maxAge": 1, "name": "Mr. Michael D. Troutman", "age": 58, "title": "Chief Information Officer", "yearBorn": 1967, "fiscalYear": 2025, "totalPay": 754846, "exercisedValue": 2727996, "unexercisedValue": 0}, {"maxAge": 1, "name": "Mr. Daniel J. Klun", "age": 50, "title": "Chief Financial Officer", "yearBorn": 1975, "fiscalYear": 2025, "exercisedValue": 0, "unexercisedValue": 0}, {"maxAge": 1, "name": "Mr. Mark W. Peterson CPA", "age": 53, "title": "Senior VP & Chief Administrative Officer", "yearBorn": 1972, "fiscalYear": 2025, "totalPay": 1317756, "exercisedValue": 1089506, "unexercisedValue": 142294}, {"maxAge": 1, "name": "Mr. Jeffrey J. LaValle", "age": 46, "title": "VP, General Counsel & Secretary", "yearBorn": 1979, "fiscalYear": 2025, "exercisedValue": 0, "unexercisedValue": 0}, {"maxAge": 1, "name": "Angela  Hersil", "title": "Vice President of Marketing, Corporate Communications & Sustainability", "fiscalYear": 2025, "exercisedValue": 0, "